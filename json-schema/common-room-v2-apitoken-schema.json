{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://api.commonroom.io/schemas/v2/apitoken",
  "title": "ApiToken",
  "type": "object",
  "properties": {
    "jti": {
      "type": "string",
