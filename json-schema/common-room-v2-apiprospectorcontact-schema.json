{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://api.commonroom.io/schemas/v2/apiprospectorcontact",
  "title": "ApiProspectorContact",
  "type": "object",
  "required": [
    "id",
    "name"
  ],
  "properties": {
    "id": {
      "type": "string",
      "description": "Prospector contact ID"
    },
    "name": {
      "type": "string",
      "description": "The contact's display name"
    },
    "avatarUrl": {
      "type": "string",
      "format": "uri",
      "nullable": true
    },
    "companyName": {
      "type": "string",
      "nullable": true
    },
    "companyWebsite": {
      "type": "string",
      "format": "uri",
      "nullable": true
    },
    "fullName": {
      "type": "string",
      "nullable": true
    },
    "linkedInFollowerCount": {
      "type": "number",
      "nullable": true
    },
    "linkedInHandle": {
      "type": "string",
      "nullable": true
    },
    "location": {
      "allOf": [
        {
          "$ref": "#/components/schemas/ApiLocation"
        }
      ],
      "nullable": true
    },
    "role": {
      "type": "string",
      "nullable": true
    },
    "seniority": {
      "type": "string",
      "nullable": true
    },
    "skills": {
      "type": "array",
      "nullable": true,
      "items": {
        "type": "string"
      }
    },
    "title": {
      "type": "string",
      "nullable": true
    }
  }
}